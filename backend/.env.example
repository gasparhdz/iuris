# Servidor
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Base de datos (obligatoria)
DATABASE_URL=postgres://user:password@localhost:5432/iuris

# Seguridad y autenticacion
JWT_SECRET=change-me-change-me
# Clave de cifrado de 32 bytes (generar con: openssl rand -base64 32)
ENCRYPTION_KEY=
# Clave anterior para rotacion; opcional salvo migracion de datos cifrados
ENCRYPTION_KEY_LEGACY=
# Clave HMAC para la cadena de auditoria (generar con: openssl rand -base64 32)
AUDIT_HMAC_KEY=
# Dominio de cookies; opcional en dev
COOKIE_DOMAIN=
# Origen CORS del frontend; obligatoria con NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# URLs publicas
APP_URL=http://localhost:5173

# Redis (colas BullMQ / SISFE sync)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Email (SMTP) — opcional; sin configurar, los emails quedan deshabilitados
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Notificaciones push (Web Push / VAPID) — opcional
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Almacenamiento de archivos
STORAGE_DRIVER=google-drive
STORAGE_CONCURRENCY=4
STORAGE_INTERVAL_CAP=8
STORAGE_INTERVAL_MS=1000
STORAGE_WEBHOOK_SECRET=
STORAGE_WEBHOOK_BASE_URL=

# S3 — obligatorias solo si STORAGE_DRIVER=s3
S3_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Google Drive — requeridas para STORAGE_DRIVER=google-drive en produccion
DRIVE_ROOT_FOLDER_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# SISFE (integracion judicial Santa Fe)
SISFE_CONCURRENCY=2
SISFE_SYNC_MODE=browser
SISFE_DIAS_NOVEDADES=7
